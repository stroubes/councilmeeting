NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/council_meeting
AUTH_BYPASS_ENABLED=false
AUTH_BYPASS_ALLOWED_ENVS=development,test,local
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GENERAL_MAX=120
RATE_LIMIT_PUBLIC_MAX=90
RATE_LIMIT_AUTH_MAX=30
# Comma-separated list of frontend origins allowed to call the API (CORS).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:4173

# Microsoft Identity
MS_TENANT_ID=// TODO: Add Microsoft Identity Tenant ID
MS_CLIENT_ID=// TODO: Add Microsoft Identity Client ID
MS_CLIENT_SECRET=// TODO: Add Microsoft Identity Client Secret
MS_REDIRECT_URI=http://localhost:3000/api/auth/callback
MS_API_AUDIENCE=// TODO: Add Microsoft API audience (Application ID URI or API Client ID)

# SharePoint
SHAREPOINT_TENANT=// TODO: Add SharePoint tenant
SHAREPOINT_SITE_ID=// TODO: Add SharePoint site id
SHAREPOINT_DRIVE_ID=// TODO: Add SharePoint drive id
